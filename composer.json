{
    "name": "fsnw/fsnw-key-management",
    "description": "Schlüsselverwaltung für Klienten-Wohnungen: Inventar, Ausgabe mit Tablet-Unterschrift, Rückgabe- und Verlust-Verwaltung.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "freestyle Jugendhilfe gGmbh",
            "homepage": "https://www.freestyle-jugendhilfe.de"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "classmap": [
            "frontend/",
            "includes/"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
